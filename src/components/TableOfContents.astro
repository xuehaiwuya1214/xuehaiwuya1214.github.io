---
import type { MarkdownHeading } from 'astro';

interface Props {
  headings: MarkdownHeading[];
}

const { headings } = Astro.props;
const toc = headings.filter((h) => h.depth === 2 || h.depth === 3);
---

{
  toc.length > 1 && (
    <nav class="toc" aria-label="文章目录">
      <p class="toc-title">目 录</p>
      <ul>
        {toc.map((h) => (
          <li class={`toc-item depth-${h.depth}`}>
            <a href={`#${h.slug}`}>{h.text}</a>
          </li>
        ))}
      </ul>
    </nav>
  )
}

<style>
  .toc {
    font-size: 0.85rem;
    line-height: 1.6;
  }

  .toc-title {
    margin: 0 0 10px;
    font-family: var(--font-serif);
    font-weight: 700;
    font-size: 0.9rem;
    letter-spacing: 0.3em;
    color: var(--text-muted);
  }

  .toc ul {
    list-style: none;
    margin: 0;
    padding: 0;
    border-left: 2px solid var(--border);
  }

  .toc-item a {
    display: block;
    padding: 4px 0 4px 14px;
    margin-left: -2px;
    border-left: 2px solid transparent;
    color: var(--text-muted);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    transition: all 0.15s ease;
  }

  .toc-item.depth-3 a {
    padding-left: 28px;
    font-size: 0.8rem;
  }

  .toc-item a:hover {
    color: var(--text);
  }

  .toc-item a.active {
    color: var(--accent);
    border-left-color: var(--accent);
    font-weight: 600;
  }
</style>

<script>
  // 滚动跟随高亮
  const links = document.querySelectorAll<HTMLAnchorElement>('.toc a');
  if (links.length > 0) {
    const map = new Map<Element, HTMLAnchorElement>();
    for (const link of links) {
      const id = decodeURIComponent(link.hash.slice(1));
      const target = document.getElementById(id);
      if (target) map.set(target, link);
    }
    let activeLink: HTMLAnchorElement | null = null;
    const visible = new Set<Element>();
    const observer = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          if (entry.isIntersecting) visible.add(entry.target);
          else visible.delete(entry.target);
        }
        // 取可见标题中最靠上的一个
        const first = [...map.keys()].find((el) => visible.has(el));
        if (first) {
          activeLink?.classList.remove('active');
          activeLink = map.get(first) ?? null;
          activeLink?.classList.add('active');
        }
      },
      { rootMargin: '-70px 0px -66% 0px' }
    );
    for (const target of map.keys()) observer.observe(target);
  }
</script>
