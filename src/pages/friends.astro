---
import BaseLayout from '../layouts/BaseLayout.astro';
import { FRIENDS } from '../site.config';
---

<BaseLayout title="友链" description="友情链接">
  <h1 class="page-title">友链</h1>
  <p class="page-subtitle">海内存知己，天涯若比邻。</p>

  <div class="friend-grid">
    {
      FRIENDS.map((f) => (
        <a class="friend-card" href={f.url} target="_blank" rel="noopener">
          <span class="friend-avatar">{f.name.slice(0, 1)}</span>
          <span class="friend-info">
            <span class="friend-name">{f.name}</span>
            <span class="friend-desc">{f.description}</span>
          </span>
        </a>
      ))
    }
  </div>

  <section class="apply">
    <h2>交换友链</h2>
    <p>
      欢迎交换友链！可以在
      <a href="/about/">关于页</a>
      找到我的联系方式，来信请附上你的站点名称、链接和一句话简介。
    </p>
  </section>
</BaseLayout>

<style>
  .friend-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 16px;
  }

  .friend-card {
    display: flex;
    align-items: center;
    gap: 14px;
    padding: 18px 20px;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 14px;
    box-shadow: var(--shadow);
    transition: all 0.2s ease;
  }

  .friend-card:hover {
    transform: translateY(-3px);
    border-color: var(--accent);
    box-shadow: var(--shadow-lift);
  }

  .friend-avatar {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 46px;
    height: 46px;
    flex-shrink: 0;
    border-radius: 13px;
    background: var(--accent);
    color: #fff;
    font-family: var(--font-serif);
    font-size: 1.2rem;
    font-weight: 700;
  }

  .friend-info {
    display: flex;
    flex-direction: column;
    min-width: 0;
  }

  .friend-name {
    font-weight: 650;
    color: var(--text);
  }

  .friend-card:hover .friend-name {
    color: var(--accent);
  }

  .friend-desc {
    font-size: 0.82rem;
    color: var(--text-muted);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .apply {
    margin-top: 44px;
    padding: 24px 28px;
    border: 1px dashed var(--border-strong);
    border-radius: 14px;
    color: var(--text-secondary);
  }

  .apply h2 {
    margin: 0 0 8px;
    font-family: var(--font-serif);
    font-size: 1.15rem;
  }

  .apply p {
    margin: 0;
    font-size: 0.92rem;
  }

  .apply a {
    color: var(--accent);
    text-decoration: underline;
    text-underline-offset: 3px;
  }
</style>
