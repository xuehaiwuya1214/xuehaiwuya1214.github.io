---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostCard from '../../components/PostCard.astro';
import { getPosts, groupByCategory, type Post } from '../../utils/posts';

export async function getStaticPaths() {
  const posts = await getPosts();
  return [...groupByCategory(posts).entries()].map(([category, list]) => ({
    params: { category },
    props: { category, posts: list },
  }));
}

interface Props {
  category: string;
  posts: Post[];
}

const { category, posts } = Astro.props;
---

<BaseLayout title={`分类：${category}`} description={`分类「${category}」下的全部文章`}>
  <h1 class="page-title">分类 · {category}</h1>
  <p class="page-subtitle">共 {posts.length} 篇文章 · <a class="back" href="/categories/">查看全部分类 →</a></p>

  <div class="post-list">
    {posts.map((post) => <PostCard post={post} />)}
  </div>
</BaseLayout>

<style>
  .post-list {
    display: flex;
    flex-direction: column;
    gap: 22px;
  }

  .back {
    color: var(--accent);
  }
</style>
